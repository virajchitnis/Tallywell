# Copy to .env.build (gitignored) and fill in your own values.
# Used by scripts/remote-build.sh to build/test inside Docker on a remote host
# over SSH. None of these values are ever committed.

# SSH target for a host that has Docker installed (key-based auth recommended).
TALLYWELL_BUILD_HOST=user@your-host

# Remote working directory for synced source + build output.
TALLYWELL_BUILD_DIR=~/tallywell-build

# Go toolchain image used for build/test.
TALLYWELL_GO_IMAGE=golang:1.25
